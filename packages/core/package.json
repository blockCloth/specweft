{
  "name": "@specweft/core",
  "version": "0.1.1",
  "description": "Core task preparation, Skill routing, review, memory, Agent Harness, and MCP assembly logic for SpecWeft.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blockCloth/specweft.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/blockCloth/specweft#readme",
  "bugs": {
    "url": "https://github.com/blockCloth/specweft/issues"
  },
  "keywords": [
    "agent",
    "mcp",
    "codex",
    "claude",
    "skills",
    "code-review",
    "memory"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/activity/**/*",
    "dist/assembly/**/*",
    "dist/bootstrap/**/*",
    "dist/capabilities/**/*",
    "dist/connect/**/*",
    "dist/diff/**/*",
    "dist/git/**/*",
    "dist/harness/**/*",
    "dist/marketplace/**/*",
    "dist/mcp/**/*",
    "dist/memory/**/*",
    "dist/pool/**/*",
    "dist/projects/**/*",
    "dist/recording/**/*",
    "dist/recommendations/**/*",
    "dist/requirements/**/*",
    "dist/review/**/*",
    "dist/scanner/**/*",
    "dist/security/**/*",
    "dist/schemas/**/*",
    "dist/selection/**/*",
    "dist/settings/**/*",
    "dist/status/**/*",
    "dist/task/**/*",
    "dist/utils/**/*",
    "dist/work-segments/**/*",
    "dist/index.js",
    "dist/index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "pnpm clean && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/__tests__/*.test.js"
  }
}
