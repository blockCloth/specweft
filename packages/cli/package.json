{
  "name": "specweft",
  "version": "0.1.1",
  "description": "Local context, review, memory, and Skill workflow layer for Codex, Claude, and other coding agents.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "specweft": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blockCloth/specweft.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/blockCloth/specweft#readme",
  "bugs": {
    "url": "https://github.com/blockCloth/specweft/issues"
  },
  "keywords": [
    "agent",
    "mcp",
    "codex",
    "claude",
    "skills",
    "context",
    "code-review",
    "memory"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "pnpm clean && tsc -p tsconfig.json && chmod +x dist/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@specweft/core": "workspace:*",
    "@specweft/web": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.20.0"
  }
}
