{
  "name": "@specweft/web",
  "version": "0.1.1",
  "description": "Local SpecWeft workbench for task preparation, Skill routing, review explanations, memory restore, and agent connection.",
  "license": "MIT",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blockCloth/specweft.git",
    "directory": "packages/web"
  },
  "homepage": "https://github.com/blockCloth/specweft#readme",
  "bugs": {
    "url": "https://github.com/blockCloth/specweft/issues"
  },
  "keywords": [
    "agent",
    "mcp",
    "codex",
    "claude",
    "skills",
    "review",
    "memory",
    "web-ui"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "pnpm clean && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/server.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@specweft/core": "workspace:*",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "tsx": "^4.20.0"
  }
}
